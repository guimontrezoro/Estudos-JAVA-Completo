import java.util.Scanner;

public class Main {
	
	public static void main(String[] args) {
		
		Scanner sc = new Scanner(System.in);

		
		double pi, raio, A;
		
		pi = 3.14159;
		
		raio = sc.nextDouble();
		
		Math.pow(raio, 2);
		
		A = pi * raio;
		
		System.out.println(A);
		
	sc.close();
	
	}
}
         