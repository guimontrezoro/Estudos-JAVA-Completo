import java.util.Locale;
import java.util.Scanner;

public class Main {
	
	public static void main(String[] args) {
		
		Locale.setDefault(Locale.US);
		Scanner sc = new Scanner(System.in);

		int p1, np1, p2, np2;
		double vu1, vu2;
		double valorap;
		
		p1 = sc.nextInt();
		np1 = sc.nextInt();
		p2 = sc.nextInt();
		np2 = sc.nextInt();
		vu1 = sc.nextDouble();
		vu2 = sc.nextDouble();
		
		valorap = np1 * vu1 + np2 * vu2;
		
		System.out.printf("VALOR A PAGAR: R$ %.2f", valorap);
		
		
	sc.close();
	
	}
}
         
         